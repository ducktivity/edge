# Copy to .env on the box and fill in. These are the only secrets the edge stack needs.

# The suite tunnel's CONNECTOR token (not the Access service token):
# Cloudflare Zero Trust -> Networks -> Tunnels -> <tunnel> -> Configure -> the long
# string after `install` / `--token`.
CLOUDFLARE_TUNNEL_CONNECTOR_TOKEN=eyJ...

# BetterStack log egress (the suite ships all app logs through this one shipper).
BETTERSTACK_SOURCE_TOKEN=
BETTERSTACK_INGEST_HOST=https://in.logs.betterstack.com
